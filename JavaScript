   V6 MASTER: ASSET DIAGNOSTICS & 3D MAPPING
   ============================================================= */

function renderAssetDiagnostics() {
    const container = document.getElementById('gauges-grid');
    if(!container) return;
    container.innerHTML = '';

    store.tanks.forEach(tank => {
        const color = tank.level <= 20 ? 'var(--accent-danger)' : (tank.level <= 45 ? 'var(--accent-warning)' : 'var(--primary)');
        
        const div = document.createElement('div');
        div.className = 'asset-card glass-panel';
        div.innerHTML = `
            <div class="asset-header">
                <span class="asset-id">UNIT_${tank.id}</span>
                <span class="asset-type">${tank.fuelType}</span>
            </div>
            
            <div class="tank-wireframe">
                <div class="wireframe-liquid" style="height:${tank.level}%; background:linear-gradient(to top, ${color}66, ${color}22);"></div>
                <div class="wireframe-mesh"></div>
                <div class="level-overlay">${tank.level}%</div>
            </div>

            <div class="telemetry-grid">
                <div class="tel-item"><span>FLOW</span> <strong>1.4L/s</strong></div>
                <div class="tel-item"><span>TEMP</span> <strong>-38°F</strong></div>
                <div class="tel-item"><span>VIBE</span> <strong>NOMINAL</strong></div>
                <div class="tel-item"><span>HLTH</span> <strong>98%</strong></div>
            </div>
        `;
        container.appendChild(div);
    });
}

// 3D Map Initialization (Placeholder for Mapbox/Three.js)
function initArcticMap() {
    const mapEl = document.getElementById('arctic-map-3d');
    if(!mapEl) return;
    mapEl.innerHTML = `
        <div class="map-mesh-bg"></div>
        <div class="map-ui-overlay">
            <div class="pulsing-node" style="top:40%; left:50%;"></div>
            <div class="node-label" style="top:42%; left:52%;">North Pole HQ</div>
        </div>
    `;
}
